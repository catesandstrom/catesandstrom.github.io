/* ========================================
   Cate Sandstrom - Traditional Irish Fiddler
   Clean, Elegant, Professional Design
   ======================================== */

:root {
    --bg-color: #f5f5f5;
    --text-color: #333333;
    --heading-color: #1a1a1a;
    --link-color: #333333;
    --link-hover: #666666;
    --accent-color: #F8BFAA;
    --accent-hover: #E5A894;
    --bootcamp-green: #93b29f;
    --bootcamp-dark: #4A5D52;
    --light-gray: #e8e8e8;
    --transition: all 0.3s ease;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: var(--bg-color);
    color: var(--text-color);
    line-height: 1.8;
    font-size: 15px;
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
    font-family: 'Work Sans', sans-serif;
    color: var(--heading-color);
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 1rem;
}

h1 {
    font-size: 3rem;
    letter-spacing: -0.02em;
}

h2 {
    font-size: 2rem;
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
}

h3 {
    font-size: 1.5rem;
}

p {
    margin-bottom: 1.2rem;
}

a {
    color: var(--link-color);
    text-decoration: none;
    transition: var(--transition);
}

a:hover {
    color: var(--link-hover);
}

/* Header & Navigation */
header {
    background-color: var(--bg-color);
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--light-gray);
    position: sticky;
    top: 0;
    z-index: 1000;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
}

nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-family: 'Work Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.02em;
}

.nav-links {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 1.5rem;
}

.nav-links a {
    font-size: 0.95rem;
    text-transform: capitalize;
    letter-spacing: 0.03em;
    position: relative;
}

.nav-links a::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--accent-color);
    transition: width 0.3s ease;
}

.nav-links a:hover::after {
    width: 100%;
}

.social-icon {
    font-size: 1.2rem;
    transition: var(--transition);
}

.social-icon:hover {
    opacity: 0.7;
}

/* Mobile Menu Toggle */
.menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-color);
}

/* Hero Section */
.hero {
    direction: rtl;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding: 4rem 0;
    min-height: 70vh;
}

.hero-content h1 {

.hero-content,
.hero-image-container {
    direction: ltr;
}
    margin-bottom: 0.5rem;
}

.hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-color);
    margin-bottom: 2rem;
    line-height: 1.6;
}

.hero-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 2px;
}

/* Content Sections */
section {
    padding: 4rem 0;
}

.content-section {
    max-width: 900px;
    margin: 0 auto;
}

.text-center {
    text-align: center;
}

/* Two Column Layout */
.two-column {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-bottom: 4rem;
}

.two-column img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 2px;
}

.two-column.reverse {
    direction: rtl;
}

.two-column.reverse > * {
    direction: ltr;
}

/* Photo Carousel */
.photo-carousel {
    background-color: white;
    padding: 3rem 0;
    overflow: hidden;
    margin-top: 3rem;
}

.carousel-track {
    display: flex;
    gap: 1.5rem;
    animation: scroll 30s linear infinite;
}

.carousel-image {
    min-width: 300px;
    height: 200px;
    object-fit: cover;
    border-radius: 2px;
}

@keyframes scroll {
    0% {
        transform: translateX(0);
    }
    100% {
        transform: translateX(-50%);
    }
}

/* Buttons & CTAs */
.btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    background-color: var(--accent-color);
    color: white;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    transition: var(--transition);
    text-align: center;
    border-radius: 2px;
}

.btn:hover {
    background-color: var(--accent-hover);
    color: white;
    transform: translateY(-2px);
}

.btn-link {
    text-decoration: underline;
    font-weight: 600;
}

/* Forms */
.form-group {
    margin-bottom: 1.5rem;
}

label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
}

input,
textarea {
    width: 100%;
    padding: 0.8rem;
    border: 1px solid var(--light-gray);
    background-color: white;
    font-family: 'Lora', serif;
    font-size: 1rem;
    transition: var(--transition);
}

input:focus,
textarea:focus {
    outline: none;
    border-color: var(--accent-color);
}

textarea {
    min-height: 150px;
    resize: vertical;
}

/* Newsletter Signup */
.newsletter-signup {
    background-color: white;
    padding: 3rem 0;
    text-align: center;
}

.newsletter-form {
    max-width: 700px;
    margin: 2rem auto 0;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
}

.newsletter-form input {
    flex: 1;
    min-width: 250px;
}

/* Calendar/Events */
.event-list {
    list-style: none;
    max-width: 700px;
    margin: 2rem auto;
}

.event-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--light-gray);
}

.event-item:last-child {
    border-bottom: none;
}

/* Workshop/Class Info Box */
.info-box {
    background-color: white;
    padding: 2.5rem;
    margin: 2rem 0;
    border-left: 3px solid var(--accent-color);
}

.info-box h3 {
    margin-top: 0;
}

.info-box ul {
    margin: 1rem 0 1rem 1.5rem;
}

.info-box li {
    margin-bottom: 0.5rem;
}

/* "Now" Page Cards */
.now-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin: 3rem 0;
}

.now-card {
    background-color: white;
    padding: 2rem;
    border-radius: 2px;
}

.now-card h3 {
    margin-bottom: 1rem;
}

.now-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    margin-bottom: 1rem;
    border-radius: 2px;
}

/* Footer */
footer {
    background-color: white;
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--light-gray);
    margin-top: 4rem;
}

.footer-content {
    text-align: center;
}

.footer-social {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.footer-social a {
    font-size: 1.5rem;
}

.footer-text {
    font-size: 0.9rem;
    color: var(--text-color);
}

/* Video Embeds */
.video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    margin: 2rem 0;
}

.video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

/* Side-by-Side Videos */
.video-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
}

.video-grid .video-container {
    margin: 0;
}

/* Responsive Design */
@media (max-width: 768px) {
    .menu-toggle {
        display: block;
    }

    .nav-links {
        position: fixed;
        top: 0;
        right: -100%;
        width: 70%;
        height: 100vh;
        background-color: var(--bg-color);
        flex-direction: column;
        padding: 4rem 2rem;
        transition: right 0.3s ease;
        box-shadow: -2px 0 10px rgba(0,0,0,0.1);
    }

    .nav-links.active {
        right: 0;
    }

    .hero {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .two-column {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    h1 {
        font-size: 2.5rem;
    }

    h2 {
        font-size: 2rem;
    }

    .newsletter-form {
        flex-direction: column;
    }

    .newsletter-form input {
        min-width: 100%;
    }

    .now-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 480px) {
    .container {
        padding: 0 1rem;
    }

    h1 {
        font-size: 2rem;
    }

    h2 {
        font-size: 1.6rem;
    }

    section {
        padding: 2rem 0;
    }
}
